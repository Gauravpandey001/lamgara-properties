PORT=4000
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_BUCKET=lamgara-media-prod
PUBLIC_BASE_URL=http://localhost:4000
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me
ADMIN_PASSWORD_HASH=sha256:REPLACE_WITH_SHA256_HASH
ADMIN_JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
ADMIN_TOKEN_TTL_SECONDS=43200
INQUIRY_NOTIFICATION_EMAIL=lamgaraproperties@gmail.com
